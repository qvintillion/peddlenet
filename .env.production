# Production Environment Variables
# Festival Chat v4.5.0 - Production Ready

# WebSocket Server - MANAGED BY VERCEL DASHBOARD
# Production builds get: wss://peddlenet-websocket-server-hfttiarlja-uc.a.run.app
# Preview builds get: wss://peddlenet-websocket-server-staging-hfttiarlja-uc.a.run.app
# DO NOT set NEXT_PUBLIC_SIGNALING_SERVER here - it's set in Vercel dashboard per environment

# Build Configuration
BUILD_TARGET=production
NODE_ENV=production

# Firebase Project
FIREBASE_PROJECT_ID=festival-chat-peddlenet

# Production Features
PRODUCTION_SECURITY=true
MOBILE_OPTIMIZED=true
ADMIN_DASHBOARD_RESPONSIVE=true
